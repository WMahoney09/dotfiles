# Copy this file to ~/.secrets and fill in your values.
# This file is sourced by .zshrc — never commit the real ~/.secrets file.

# GitHub Personal Access Tokens (used by GitHub MCP servers)
export GITHUB_PERSONAL_ACCESS_TOKEN=""
export GITHUB_PERSONAL_ACCESS_TOKEN_GNAR=""

# Render (used by Render MCP server)
export RENDER_API_TOKEN=""

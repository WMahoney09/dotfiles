# Ghostty Configuration
# Voyager workflow - terminal-centric agentic development

# Theme & Colors (loaded from external file — managed by theme picker)
config-file = ?/Users/will/.config/ghostty/theme.conf

# Font Configuration
font-family = FiraCode Nerd Font
font-size = 18
font-feature = liga
font-feature = ss01

# Cursor
cursor-style = bar

# Window & Display
window-decoration = true

# Keybindings
# Splits
keybind = cmd+shift+apostrophe=new_split:right
keybind = cmd+shift+semicolon=new_split:down

# Pane Navigation (vim-style)
keybind = cmd+h=goto_split:left
keybind = cmd+j=goto_split:down
keybind = cmd+k=goto_split:up
keybind = cmd+l=goto_split:right

# Close Pane
keybind = cmd+w=close_surface
